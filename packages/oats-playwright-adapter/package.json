{
  "name": "@smartlyio/oats-playwright-adapter",
  "version": "7.8.1",
  "license": "MIT",
  "description": "Playwright adapter for Oats a Openapi3 based generator for typescript aware servers and clients",
  "private": false,
  "author": "Smartly.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf ./dist && rm -f ./tmp/*.ts",
    "build": "pnpm clean && pnpm tsc",
    "lint": "eslint --max-warnings=0 --ext .ts .",
    "lint:fix": "eslint --max-warnings=0 --ext .ts . --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smartlyio/oats.git"
  },
  "peerDependencies": {
    "@smartlyio/oats-runtime": "^6.3.0 || ^7.0.0",
    "playwright": "^1.40.0",
    "typescript": "^4.8.0 || ^5.0.0"
  },
  "keywords": [
    "oats",
    "openapi3",
    "rest",
    "generator",
    "typescript",
    "server",
    "client",
    "playwright"
  ],
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@smartlyio/oats-runtime": "workspace:^",
    "@types/node": "24.12.4",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jest": "29.15.3",
    "eslint-plugin-prettier": "5.5.6",
    "playwright": "1.58.0",
    "prettier": "3.9.3",
    "typescript": "6.0.3"
  }
}
