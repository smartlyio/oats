{
  "name": "@smartlyio/oats",
  "version": "7.7.8",
  "license": "MIT",
  "description": "Openapi3 based generator for typescript aware servers and clients",
  "private": true,
  "author": "Smartly.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "reinstall": "rm -rf node_modules && pnpm install",
    "clean": "pnpm -r --workspace-concurrency=4 --if-present run clean",
    "tsc": "tsc",
    "pretest": "pnpm run generate && node scripts/run-workspace-script.mjs pretest",
    "doc": "pnpm run generate:examples",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "lint:local": "eslint --max-warnings=0 --ext .ts test examples",
    "lint": "pnpm run lint:local && pnpm -r --if-present run lint",
    "lint:fix": "pnpm run lint:local && pnpm -r --if-present run lint:fix",
    "generate": "pnpm run generate:ejs && pnpm run generate:examples && pnpm run generate:test",
    "generate:ejs": "find test -name '*.ejs' -exec /bin/sh  -c 'pnpm ejs -o ${1%.*} $1' --hide-banner {} \\;",
    "generate:test": "find test -name 'driver.ts' -exec ts-node -r tsconfig-paths/register --project tsconfig.json {} \\;",
    "generate:examples": "ts-node -r tsconfig-paths/register --project tsconfig.json examples/driver.ts && ts-node -r tsconfig-paths/register --project tsconfig.json render.ts",
    "render": "pnpm run doc && node scripts/run-workspace-script.mjs render",
    "build": "node scripts/run-workspace-script.mjs build",
    "ci:install": "pnpm install --frozen-lockfile --reporter=silent",
    "ci:lint": "pnpm run lint",
    "ci:test": "pnpm run test",
    "ci:build": "pnpm run --silent build",
    "version-packages": "node scripts/version-packages.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smartlyio/oats.git"
  },
  "keywords": [
    "oats",
    "openapi3",
    "rest",
    "generator",
    "typescript",
    "server",
    "client"
  ],
  "devDependencies": {
    "@types/jest": "29.5.2",
    "@types/js-yaml": "4.0.9",
    "@types/koa": "2.15.0",
    "@types/koa-mount": "4.0.2",
    "@types/koa-router": "7.4.4",
    "@types/node": "18.19.130",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "ajv": "8.17.1",
    "axios": "1.14.0",
    "ejs": "3.1.10",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "27.9.0",
    "eslint-plugin-prettier": "4.2.1",
    "fast-check": "2.25.0",
    "jest": "29.7.0",
    "prettier": "2.8.8",
    "tinybench": "2.9.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.1"
  },
  "dependencies": {
    "koa": "2.16.2",
    "koa-body": "6.0.1",
    "koa-mount": "4.0.0",
    "koa-router": "12.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@10.16.0"
}
